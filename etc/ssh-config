# ~/.ssh/config に追記する内容
# VM基盤管理用のSSH設定

# Catalyst 3560-CX (古いSSH方式を許可)
Host local-router catalyst 10.0.1.1
    HostName 10.0.1.1
    User admin
    KexAlgorithms +diffie-hellman-group14-sha1
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedAlgorithms +ssh-rsa

# Catalyst 管理ネットワーク経由 (初期セットアップ用)
Host local-router-mgmt 10.1.1.1
    HostName 10.1.1.1
    User admin
    KexAlgorithms +diffie-hellman-group14-sha1
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedAlgorithms +ssh-rsa

# Proxmox VE ノード
Host mandolin1 10.1.1.11
    HostName 10.1.1.11
    User root

Host mandolin2 10.1.1.12
    HostName 10.1.1.12
    User root

Host mandolin3 10.1.1.13
    HostName 10.1.1.13
    User root

# Proxmox ノード共通設定 (ワイルドカード)
Host mandolin*
    User root
    # 初回セットアップ時のみ
    # StrictHostKeyChecking no
    # UserKnownHostsFile /dev/null
