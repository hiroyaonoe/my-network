# /etc/hosts に追記する内容
# VM基盤管理用のホスト名定義

# ローカルルータ / L3スイッチ
192.168.1.1     local-router catalyst        # WAN側インターフェース (通常使用)
172.16.0.1      local-router-mgmt            # 管理ネットワーク (初期セットアップ用)

# Proxmox VE クラスタ: mandolin
# 管理ネットワーク (VLAN 10)
172.16.0.11     mandolin1
172.16.0.12     mandolin2
172.16.0.13     mandolin3

# Ceph クラスタネットワーク (VLAN 20) - 参考
# 172.16.1.11     mandolin1-ceph
# 172.16.1.12     mandolin2-ceph
# 172.16.1.13     mandolin3-ceph

# WAN側ルータ (参考)
# 192.168.0.1     wan-router

